{
  "providers": {
    "ollama-cloud": {
      "type": "ollama",
      "apiKey": "env:OLLAMA_API_KEY"
    }
  },
  "routing": {
    "routerModel": "ollama-cloud/qwen3.6-plus:cloud",
    "roles": {
      "primary": {
        "model": "ollama-cloud/qwen3.6-plus:cloud",
        "thinkingLevel": "high"
      },
      "planner": {
        "model": "ollama-cloud/qwen3.6-plus:cloud"
      },
      "reviewer": {
        "model": "ollama-cloud/glm-5.1:cloud"
      },
      "explore": {
        "model": "ollama-cloud/glm-5.1:cloud"
      },
      "documenter": {
        "model": "ollama-cloud/llama-4-mini:cloud"
      },
      "summarizer": {
        "model": "ollama-cloud/llama-4-mini:cloud"
      },
      "vision": {
        "model": "ollama-cloud/pi-vision-1.5:cloud"
      },
      "tester": {
        "model": "ollama-cloud/deepseek-v4-coder:cloud"
      },
      "refactorer": {
        "model": "ollama-cloud/deepseek-v4-coder:cloud"
      }
    },
    "contextPromotion": {
      "enabled": true,
      "fallbackModel": "ollama-cloud/qwen3.6-plus:cloud"
    }
  },
  "providers": {
    "ollama": { "enabled": false },
    "google": { "enabled": false },
    "anthropic": { "enabled": false },
    "openai": { "enabled": false },
    "ollama-cloud": {
      "type": "ollama",
      "apiKey": "env:OLLAMA_API_KEY"
    }
  }
}
