{
  "routing": {
    "routerModel": "ollama/glm-5.1:cloud",
    "roles": {
      "primary": {
        "model": "ollama/glm-5.1:cloud",
        "thinkingLevel": "high"
      },
      "planner": {
        "model": "ollama/qwen3.5:cloud"
      },
      "reviewer": {
        "model": "ollama/glm-5.1:cloud"
      },
      "explore": {
        "model": "ollama/glm-5.1:cloud"
      },
      "documenter": {
        "model": "ollama/ministral-3:14b-cloud"
      },
      "summarizer": {
        "model": "ollama/ministral-3:14b-cloud"
      },
      "vision": {
        "model": "ollama/qwen3.5:cloud"
      },
      "tester": {
        "model": "ollama/qwen3-coder-next:cloud"
      },
      "refactorer": {
        "model": "ollama/qwen3-coder-next:cloud"
      }
    },
    "contextPromotion": {
      "enabled": true,
      "fallbackModel": "ollama/qwen3.5:cloud"
    }
  },
  "providers": {
    "ollama": {
      "type": "ollama",
      "enabled": true,
      "baseUrl": "http://localhost:11434"
    },
    "google": { "enabled": false },
    "anthropic": { "enabled": false },
    "openai": { "enabled": false }
  }
}
